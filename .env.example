# Application settings
PORT=8080
ENVIRONMENT=development

# Database path (relative to container app directory, mounted to host ./data)
DB_PATH=/app/data

# Secret key for encrypting sensitive user data (e.g. email in DB)
# Must be exactly 32 bytes for AES-256 GCM (e.g., "supersecretkey32byteslongexample!")
ENCRYPTION_KEY=supersecretkey32byteslongexample!

# Server-side encryption for embedding vectors at rest (base64-encoded 32 bytes).
# Generate: openssl rand -base64 32
NOTEIKA_EMBEDDING_KEY=

# GitHub OAuth settings (Leave empty or set to "mock" to use Mock developer authentication)
GITHUB_OAUTH_CLIENT_ID=mock
GITHUB_OAUTH_CLIENT_SECRET=mock
GITHUB_OAUTH_REDIRECT_URI=http://localhost:8080/auth/github/callback

# Google OAuth settings (Leave empty or set to "mock" to use Mock developer authentication)
GOOGLE_OAUTH_CLIENT_ID=mock
GOOGLE_OAUTH_CLIENT_SECRET=mock
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8080/auth/google/callback

# Stripe billing (optional — leave empty to disable checkout in dev)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
# Public URL for Stripe redirect (defaults to request host if empty)
APP_PUBLIC_URL=http://localhost:8080

# Plan limits
NOTEIKA_FREE_CAPTURE_LIMIT=10
# Always Pro — your login email (optional)
NOTEIKA_OWNER_EMAIL=
